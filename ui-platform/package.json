{
  "name": "@karan9186/workspace",
  "version": "1.0.3",
  "description": "Monorepo workspace for the UI Library design system.",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm --filter ./packages/core --filter ./packages/web-components --filter ./packages/react --filter ./packages/angular -r build",
    "dev": "pnpm --filter ./packages/core --filter ./packages/web-components --filter ./packages/react --filter ./packages/angular -r --parallel run dev",
    "publish:prepare": "pnpm run build && node scripts/prepare-publish.js",
    "publish:dry-run": "node scripts/publish-packages.js --dry-run",
    "publish:all": "node scripts/publish-packages.js",
    "test": "echo \"No root test runner configured\"",
    "build2": "pnpm -r build && node scripts/build-all.js",
    "pack:tarball": "pnpm run build2 && npm pack --ignore-scripts",
    "prepack": "pnpm -r build && node scripts/build-all.js",
    "karan9186": "pnpm -r --parallel run dev"
  },
  "pnpm": {
    "overrides": {
      "@angular/*": "21.2.3"
    }
  },
  "license": "ISC",
  "packageManager": "pnpm@10.32.1",
  "devDependencies": {
    "@angular/build": "^21.2.3",
    "@angular/cli": "^21.2.3",
    "@angular/common": "^21.2.3",
    "@angular/compiler": "^21.2.3",
    "@angular/core": "^21.2.3",
    "@angular/forms": "^21.2.3",
    "@angular/platform-browser": "^21.2.3",
    "@angular/platform-browser-dynamic": "^21.2.3",
    "@stencil/core": "^4.43.3",
    "fs-extra": "^11.3.4",
    "rxjs": "~7.8.2",
    "zone.js": "^0.16.1"
  }
}