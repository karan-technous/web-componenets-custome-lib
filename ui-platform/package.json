{
  "name": "ui-platform",
  "version": "1.0.0",
  "description": "Stencil web components with Angular and React wrappers. Tarball: pnpm run build && npm pack",
  "private": false,
  "type": "module",
  "main": "./dist/web-components/index.esm.js",
  "module": "./dist/web-components/index.esm.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/web-components/index.esm.js",
      "default": "./dist/web-components/index.esm.js"
    },
    "./loader": {
      "types": "./dist/loader/index.d.ts",
      "import": "./dist/loader/index.js",
      "require": "./dist/loader/index.cjs.js",
      "default": "./dist/loader/index.js"
    },
    "./components": {
      "types": "./dist/types/components.d.ts",
      "import": "./dist/web-components/web-components.esm.js",
      "default": "./dist/web-components/web-components.esm.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js",
      "default": "./dist/react/index.js"
    },
    "./angular": {
      "types": "./dist/angular/ui-lib/types/ui-platform-angular.d.ts",
      "import": "./dist/angular/ui-lib/fesm2022/ui-platform-angular.mjs",
      "default": "./dist/angular/ui-lib/fesm2022/ui-platform-angular.mjs"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js",
      "default": "./dist/core/index.js"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": [
    "./dist/web-components/*.js",
    "./dist/loader/*.js",
    "./dist/react/setup.js",
    "./dist/react/index.js"
  ],
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm -r build && node scripts/build-all.js",
    "pack:tarball": "pnpm run build && npm pack --ignore-scripts",
    "prepack": "pnpm -r build && node scripts/build-all.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "ui-library": "pnpm -r --parallel run dev"
  },
  "keywords": [],
  "author": "",
  "peerDependencies": {
    "@angular/common": "^21.0.0",
    "@angular/core": "^21.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "@angular/common": {
      "optional": true
    },
    "@angular/core": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "pnpm": {
    "overrides": {
      "@angular/*": "21.2.3"
    }
  },
  "license": "ISC",
  "packageManager": "pnpm@10.32.1",
  "devDependencies": {
    "@angular/build": "^21.2.3",
    "@angular/cli": "^21.2.3",
    "@angular/common": "^21.2.3",
    "@angular/compiler": "^21.2.3",
    "@angular/core": "^21.2.3",
    "@angular/forms": "^21.2.3",
    "@angular/platform-browser": "^21.2.3",
    "@angular/platform-browser-dynamic": "^21.2.3",
    "@stencil/core": "^4.43.3",
    "fs-extra": "^11.3.4",
    "rxjs": "~7.8.2",
    "zone.js": "^0.16.1"
  }
}
