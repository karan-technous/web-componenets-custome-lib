  "keywords": [
    "design-system",
    "karan9186",
    "web-components",
    "cli"
  ],
  "author": "",
  "license": "ISC",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@karan9186/core": "1.0.4",
    "@karan9186/web-components": "1.0.4",
    "chalk": "^5.6.2",
    "ora": "^8.2.0",
    "prompts": "^2.4.2"
  }
}
