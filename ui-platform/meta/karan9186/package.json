{
  "name": "@karan9186/main",
  "version": "1.0.4",
  "description": "Base package and CLI for the UI Library design system.",
  "type": "module",
  "bin": {
    "karan9186": "cli.js"
  },
  "exports": {
    "./core": {
      "types": "./core.d.ts",
      "import": "./core.js",
      "default": "./core.js"
    },
    "./web-components": {
      "types": "./web-components.d.ts",
      "import": "./web-components.js",
      "default": "./web-components.js"
    },
    "./loader": {
      "types": "./loader.d.ts",
      "import": "./loader.js",
      "default": "./loader.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "cli.js",
    "core.js",
    "core.d.ts",
    "web-components.js",
    "web-components.d.ts",
    "loader.js",
    "loader.d.ts"
