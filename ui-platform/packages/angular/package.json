    "@angular/platform-browser": "^21.2.3",
    "@angular/router": "^21.2.3",
    "@karan9186/core": "workspace:*",
    "@karan9186/web-components": "workspace:*",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "21.2.3",
    "@angular/cli": "^21.2.3",
    "@angular/compiler-cli": "^21.2.3",
    "@types/jasmine": "~5.1.0",
    "jasmine-core": "~5.9.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
