{
  "name": "@karan9186/web-components",
  "version": "1.0.6",
  "description": "Stencil Component Starter",
  "main": "dist/index.cjs.js",
  "module": "dist/index.js",
  "types": "dist/types/index.d.ts",
  "collection": "dist/collection/collection-manifest.json",
  "collection:main": "dist/collection/index.js",
  "unpkg": "dist/web-components/web-components.esm.js",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs.js"
    },
    "./loader": {
      "types": "./dist/loader/index.d.ts",
      "import": "./dist/loader/index.js",
      "require": "./dist/loader/index.cjs.js"
    },
    "./web-components": {
      "types": "./dist/types/components.d.ts",
      "import": "./dist/web-components/web-components.esm.js",
      "default": "./dist/web-components/web-components.esm.js"
    },
    "./components/ui-button": {
      "import": "./dist/components/ui-button.js",
      "types": "./dist/components/ui-button.d.ts"
    },
    "./components/ui-input": {
      "import": "./dist/components/ui-input.js",
      "types": "./dist/components/ui-input.d.ts"
    },
    "./types": {
      "types": "./dist/types/types/index.d.ts",
      "import": "./dist/types/types/index.js"
    },
    "./types/*": {
      "types": "./dist/types/types/*.d.ts",
      "import": "./dist/types/types/*.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/stenciljs/component-starter.git"
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "prebuild": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "stencil build",
    "dev": "stencil build --watch --serve",
    "start": "stencil build --dev --watch --serve",
    "test": "stencil-test",
    "test:watch": "stencil-test --watch",
    "generate": "stencil generate"
  },
  "devDependencies": {
    "@stencil/core": "^4.27.1",
    "@stencil/vitest": "^1.8.3",
    "@types/node": "^22.13.5",
    "@vitest/browser-playwright": "^4.0.0",
    "vitest": "^4.0.0"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@karan9186/core": "workspace:*",
    "lucide": "^1.7.0"
  }
}
