{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "jsx": "react",
    "jsxFactory": "h",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": false,
    "moduleResolution": "bundler",
    "types": ["@stencil/core"]
  },
  "include": ["src"],
  "exclude": ["src/**/*.test.ts", "src/**/*.spec.ts", "src/**/*.cmp.test.ts"]
}
